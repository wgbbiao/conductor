{
  "name": "conductor",
  "private": true,
  "version": "0.0.0",
  "engines": { "node": ">=20.10", "pnpm": ">=9.0" },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @conductor/db exec prisma generate",
    "db:migrate": "pnpm --filter @conductor/db exec prisma migrate dev"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
